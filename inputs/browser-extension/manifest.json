{
  "manifest_version": 3,
  "name": "Jenn Input",
  "version": "1.0.0",
  "description": "Отправляйте текст и закладки в Jenn Core",
  "permissions": ["storage", "activeTab", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Jenn Input"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
