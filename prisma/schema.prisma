// ponytail: dev=sqlite. Prod: switch provider to "postgresql" + `prisma migrate deploy`.
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  tokens       Token[]
  config       UserConfig?
  messages     Message[]
}

model Token {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  source    String
  token     String   @unique
  createdAt DateTime @default(now())

  @@unique([userId, source])
  @@index([token])
}

model UserConfig {
  userId    String   @id
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  data      Json
  updatedAt DateTime @updatedAt
}

model Message {
  id          String   @id @default(uuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  source      String
  text        String
  userMeta    Json?
  meta        Json?
  receivedAt  DateTime @default(now())
  result      Json?

  @@index([userId, receivedAt])
  @@index([source])
}
