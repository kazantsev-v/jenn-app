# Jenn — Environment Variables Template
# Copy to .env and fill in your keys

# AI Providers
GROQ_KEY=gsk_...
OPENROUTER_KEY=sk-or-...
GIGACHAT_KEY=<base64 auth key>
GIGACHAT_CLIENT_ID=...
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# Notion
NOTION_API_KEY=ntn_...

# Google Sheets (optional)
GSHEETS_CLIENT_EMAIL=...@...iam.gserviceaccount.com
GSHEETS_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...
GSHEETS_SHEET_ID=...

# Telegram Bot (optional)
TG_BOT_TOKEN=...
TG_CHAT_ID=...
BOT_TOKEN=...

# JWT Secret (change in production!)
JWT_SECRET=your-secret-key-here

# Server
PORT=3000

# Database (Prisma). Dev=sqlite, prod=postgresql.
# Dev:  DATABASE_URL=file:./prisma/dev.db   (provider="sqlite" in schema.prisma)
# Prod: DATABASE_URL=postgresql://user:pass@host:5432/jenn  (provider="postgresql" + `prisma migrate deploy`)
DATABASE_URL=file:./prisma/dev.db
JENN_DB_LOG=0